{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Noofy",
  "version": "0.1.0",
  "identifier": "app.noofy.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
