{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Noofy",
  "version": "0.1.0",
  "identifier": "app.noofy.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build && npm run tauri:verify-runtime",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["noofy"],
        "name": "Noofy Workflow Package",
        "description": "Noofy workflow package",
        "mimeType": "application/x-noofy-workflow",
        "role": "Editor",
        "rank": "Owner",
        "exportedType": {
          "identifier": "app.noofy.workflow-package",
          "conformsTo": ["public.data"]
        }
      }
    ],
    "windows": {
      "nsis": {
        "installerHooks": "installer-hooks.nsh"
      }
    },
    "resources": {
      "resources/noofy-runtime": "noofy-runtime",
      "../../backend/app": "noofy-runtime/backend/app",
      "../../backend/pyproject.toml": "noofy-runtime/backend/pyproject.toml",
      "../../third_party/comfyui": "noofy-runtime/comfyui"
    }
  }
}
