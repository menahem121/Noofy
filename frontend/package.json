{
  "name": "noofy-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "tauri:download-runtime": "node scripts/downloadPackagedRuntime.mjs",
    "tauri:prepare-runtime": "node scripts/preparePackagedRuntime.mjs",
    "tauri:sign-runtime": "node scripts/signPackagedRuntime.mjs",
    "tauri:verify-runtime": "node scripts/verifyPackagedRuntime.mjs",
    "tauri:smoke-backend": "node scripts/smokePackagedBackend.mjs",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "check:no-comfyui-calls": "node ../scripts/check-no-comfyui-calls.mjs",
    "test": "vitest --run --environment jsdom && npm run test:runtime-scripts",
    "test:runtime-scripts": "node --test scripts/*.node.mjs",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@sparkjsdev/spark": "^0.1.10",
    "@tauri-apps/api": "^2.10.1",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "0.170.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "0.170.0",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.1.1",
    "typescript": "^5.6.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.5"
  }
}
